              rel="noopener noreferrer"
              >#130, 4520 16 Ave. NW Calgary, AB, T3B 0M6</a
            >
          </li>
          <li>
            <i class="fas fa-phone-alt"></i>
            <a href="tel:(587) 216-8132">(587) 216-8132</a>
          </li>
          <li>
            <i class="fas fa-fax"></i>
            <span>(587) 504-2947</span>
          </li>
          <li>
            <i class="fas fa-envelope"></i>
            <a
              href="mailto:%64%72%2E%61%6B%69%6C%67%6F%75%72%40%67%6D%61%69%6C%2E%63%6F%6D"
            >
              dr.akilgour@gmail.com
            </a>
          </li>
          <li>
            <i class="fas fa-globe"></i>
            <a
              href="https://akneuropsych.com"
              target="_blank"
              rel="noopener noreferrer">akneuropsych.com</a
            >
