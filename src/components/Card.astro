---
import "../styles/card.scss";

const { title, icon, description } = Astro.props;
---

<div class="col-12 col-md-6 col-lg-3">
  <div class="card shadow-sm h-100">
    <div
      class="card-body d-flex flex-column align-items-center justify-content-start gap-4"
    >
      <i class={`icon ${icon}`}></i>
      <h5 class="card-title h5 mb-0">{title}</h5>
      <p class="card-text">
        {description}
      </p>
    </div>
  </div>
</div>
