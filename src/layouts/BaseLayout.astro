---
import "../styles/main.scss"; // Adjust path if needed
import "../styles/base-layout.scss";
const { title = "A.K. Neuropsychology" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="AK Neuropsych provides neuropsychological assessments and consultations in Alberta and Manitoba. Specializing in brain injury, concussion, and cognitive care." />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "A.K. Neuropsychology",
        "url": "https://akneuropsych.com",
        "logo": "https://akneuropsych.com/images/logo.png",
      }
    </script>
  </head>
  <body class="">
    <slot name="nav" />
    <main class="container-fluid p-0">
      <slot />
    </main>
    <slot name="book-appointment" />
    <slot name="footer" />
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    ></script>
  </body>
</html>
