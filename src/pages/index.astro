---
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
import BookAppointment from "../components/BookAppointment.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="AK Neuropsychology - Home">
  <slot name="nav"><NavBar /></slot>

  <section class="hero bg-primary text-white text-center">
    <div class="container py-5">
      <h1 class="display-4">Your Health, Our Mission</h1>
      <p class="lead">Compassionate care for your whole family</p>
      <a href="/contact" class="btn btn-light mt-3">Book an Appointment</a>
    </div>
  </section>

  <slot name="book-appointment"><BookAppointment /></slot>
  <slot name="footer"><Footer /></slot>
</BaseLayout>
